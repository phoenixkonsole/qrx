
{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QRX Wallet",
  "version": "0.1.0",
  "identifier": "org.qrx.wallet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QRX Wallet",
        "width": 1440,
        "height": 940,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
